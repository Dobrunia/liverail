{
  "name": "liverail",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p packages/contracts/tsconfig.build.json && tsc -p packages/server/tsconfig.build.json && tsc -p packages/client/tsconfig.build.json",
    "typecheck": "tsc -p packages/contracts/tsconfig.json --noEmit && tsc -p packages/server/tsconfig.json --noEmit && tsc -p packages/client/tsconfig.json --noEmit",
    "test": "node --test packages/contracts/tests/primitives.test.ts packages/contracts/tests/shared-types.test.ts packages/contracts/tests/registry.test.ts packages/contracts/tests/schema-validation-base.test.ts packages/contracts/tests/command-contracts.test.ts packages/contracts/tests/event-contracts.test.ts packages/contracts/tests/channel-contracts.test.ts packages/contracts/tests/error-model.test.ts packages/contracts/tests/validation-error-normalization.test.ts packages/contracts/tests/policy-primitives.test.ts packages/contracts/tests/policy-composition.test.ts packages/server/tests/runtime-core.test.ts packages/server/tests/command-execution-pipeline.test.ts packages/server/tests/event-emission-pipeline.test.ts packages/server/tests/channel-membership-runtime.test.ts packages/server/tests/connection-policy-enforcement.test.ts packages/server/tests/join-policy-enforcement.test.ts packages/server/tests/command-policy-enforcement.test.ts packages/server/tests/receive-policy-enforcement.test.ts packages/client/tests/runtime-core.test.ts packages/client/tests/command-client-api.test.ts packages/client/tests/channel-subscription-api.test.ts packages/client/tests/event-listener-api.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}
