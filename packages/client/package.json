{
  "name": "liverail/client",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "LiveRail client runtime for typed channels, commands and subscriptions.",
  "keywords": [
    "liverail",
    "realtime",
    "client",
    "socket.io",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dobrunia/liverail.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/Dobrunia/liverail/tree/main/packages/client",
  "bugs": {
    "url": "https://github.com/Dobrunia/liverail/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./socket-io": {
      "types": "./dist/socket-io-entry.d.ts",
      "import": "./dist/socket-io-entry.js"
    }
  },
  "dependencies": {
    "@liverail/contracts": "0.0.0"
  },
  "peerDependencies": {
    "socket.io-client": "^4.8.3"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    }
  }
}
