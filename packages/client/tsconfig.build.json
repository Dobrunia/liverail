{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@liverail/contracts": [
        "../contracts/dist/index.d.ts"
      ]
    },
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "tests/**/*.test.ts",
    "types/**/*.ts"
  ]
}
