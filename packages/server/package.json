{
  "name": "@dobrunia-liverail/server",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "LiveRail server runtime with policies, lifecycle hooks and adapters.",
  "keywords": [
    "liverail",
    "realtime",
    "server",
    "socket.io",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dobrunia/liverail.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/Dobrunia/liverail/tree/main/packages/server",
  "bugs": {
    "url": "https://github.com/Dobrunia/liverail/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./socket-io": {
      "types": "./dist/socket-io-entry.d.ts",
      "import": "./dist/socket-io-entry.js"
    }
  },
  "dependencies": {
    "@dobrunia-liverail/contracts": "^1.0.0"
  },
  "peerDependencies": {
    "socket.io": "^4.8.3"
  },
  "peerDependenciesMeta": {
    "socket.io": {
      "optional": true
    }
  }
}
